      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "kv_t" }]
    },
    {
      "type": "text", "id": "kv_t", "containerId": "kv", "x": 620, "y": 312, "width": 200, "height": 45,
      "text": "Azure Key Vault\nzafronix-wc-key (secret)",
      "fontSize": 14, "fontFamily": 2, "strokeColor": "#000000",
      "textAlign": "center", "verticalAlign": "middle"
    },

    {
      "type": "rectangle", "id": "sql", "x": 900, "y": 200, "width": 240, "height": 120,
