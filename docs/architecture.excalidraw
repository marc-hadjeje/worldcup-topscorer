{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "appState": { "viewBackgroundColor": "#ffffff" },
  "elements": [
    {
      "type": "text", "id": "title", "x": 40, "y": 20, "width": 1100, "height": 45,
      "text": "World Cup Top Scorer — Architecture (powered by Rayfin)",
      "fontSize": 28, "fontFamily": 2, "strokeColor": "#000000",
      "textAlign": "left", "verticalAlign": "top"
    },
    {
      "type": "text", "id": "lane1lbl", "x": 40, "y": 82, "width": 600, "height": 25,
      "text": "Rafraîchissement des stats (Microsoft Fabric)",
      "fontSize": 16, "fontFamily": 2, "strokeColor": "#000000",
      "textAlign": "left", "verticalAlign": "top"
    },

    {
      "type": "rectangle", "id": "api", "x": 40, "y": 120, "width": 210, "height": 100,
      "strokeColor": "#0078D4", "backgroundColor": "#CFE4FA", "fillStyle": "solid",
      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "api_t" }]
    },
    {
      "type": "text", "id": "api_t", "containerId": "api", "x": 50, "y": 145, "width": 190, "height": 60,
      "text": "Zafronix WC API\nbuts & matchs 2026",
      "fontSize": 16, "fontFamily": 2, "strokeColor": "#000000",
      "textAlign": "center", "verticalAlign": "middle"
    },

    {
      "type": "rectangle", "id": "pipeline", "x": 320, "y": 120, "width": 220, "height": 100,
      "strokeColor": "#F7630C", "backgroundColor": "#FFF4CE", "fillStyle": "solid",
      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "pipeline_t" }]
    },
    {
      "type": "text", "id": "pipeline_t", "containerId": "pipeline", "x": 330, "y": 140, "width": 200, "height": 70,
      "text": "Fabric Data Pipeline\npl-update-worldcup-stats\nschedule : toutes les 3h",
      "fontSize": 14, "fontFamily": 2, "strokeColor": "#000000",
      "textAlign": "center", "verticalAlign": "middle"
    },

    {
      "type": "rectangle", "id": "notebook", "x": 610, "y": 120, "width": 220, "height": 100,
      "strokeColor": "#F7630C", "backgroundColor": "#FFF4CE", "fillStyle": "solid",
      "strokeWidth": 2, "roundness": { "type": 3 },
      "boundElements": [{ "type": "text", "id": "notebook_t" }]
    },
    {
      "type": "text", "id": "notebook_t", "containerId": "notebook", "x": 620, "y": 140, "width": 200, "height": 70,
      "text": "Fabric Notebook\nupdate-worldcup-stats\nPython : agrège + UPSERT",
      "fontSize": 14, "fontFamily": 2, "strokeColor": "#000000",
      "textAlign": "center", "verticalAlign": "middle"
    },

    {
